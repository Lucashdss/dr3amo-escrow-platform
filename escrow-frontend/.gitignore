# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.codex/
.vscode/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.development.local
!.env.example

# database (local artifacts, dumps, and secrets)
*.sqlite
*.sqlite3
*.db
*.db-*
*.sql.gz
*.sql.zip
*.dump
*.bak
db_data/
database-data/
mysql-data/
mariadb-data/
postgres-data/
mongodb-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts



# nested frontend app
/escrow-frontend/node_modules/
/escrow-frontend/.pnp
/escrow-frontend/.pnp.*
/escrow-frontend/.yarn/*
!/escrow-frontend/.yarn/patches
!/escrow-frontend/.yarn/plugins
!/escrow-frontend/.yarn/releases
!/escrow-frontend/.yarn/versions
/escrow-frontend/coverage/
/escrow-frontend/.next/
/escrow-frontend/out/
/escrow-frontend/build/
/escrow-frontend/.DS_Store
/escrow-frontend/*.pem
/escrow-frontend/.codex/
/escrow-frontend/.agents/
/escrow-frontend/.vscode/
/escrow-frontend/npm-debug.log*
/escrow-frontend/yarn-debug.log*
/escrow-frontend/yarn-error.log*
/escrow-frontend/.pnpm-debug.log*
/escrow-frontend/.env*
/escrow-frontend/.env.local
/escrow-frontend/.env.development.local
!/escrow-frontend/.env.example
/escrow-frontend/*.sqlite
/escrow-frontend/*.sqlite3
/escrow-frontend/*.db
/escrow-frontend/*.db-*
/escrow-frontend/*.sql.gz
/escrow-frontend/*.sql.zip
/escrow-frontend/*.dump
/escrow-frontend/*.bak
/escrow-frontend/db_data/
/escrow-frontend/database-data/
/escrow-frontend/mysql-data/
/escrow-frontend/mariadb-data/
/escrow-frontend/postgres-data/
/escrow-frontend/mongodb-data/
/escrow-frontend/.vercel/
/escrow-frontend/*.tsbuildinfo
/escrow-frontend/next-env.d.ts